# ============================================
# Meeting Auto-Recorder — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# --- IMAP (email reading for meeting invites) ---
# For Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_FOLDER=INBOX

# --- Meeting Recording ---
RECORDING_FPS=10
AUTO_OPEN_MEETING=true    # Auto-open meeting URL in default browser
